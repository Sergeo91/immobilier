# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/achat_location?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="CHANGE_ME_MIN_32_CHARS_PRODUCTION"
JWT_REFRESH_SECRET="CHANGE_ME_DIFFERENT_32_CHARS"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Argon2
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3

# Stripe
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# S3 Storage
S3_ENDPOINT="https://s3.amazonaws.com"
S3_ACCESS_KEY="xxx"
S3_SECRET_KEY="xxx"
S3_BUCKET="achat-location-uploads"
S3_REGION="eu-west-1"

# ElasticSearch
ELASTICSEARCH_URL="http://localhost:9200"

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN="pk.xxx"
MAPBOX_TOKEN="pk.xxx"

# Sentry
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
SUPER_ADMIN_SECRET_PATH="ss91-admin-global"
MAINTENANCE_MODE="false"

# Mobile Money (abstraction)
MOBILE_MONEY_PROVIDER="mock"
MOBILE_MONEY_API_KEY=""
MOBILE_MONEY_WEBHOOK_SECRET=""

# Email (optionnel - mock par défaut)
EMAIL_PROVIDER="mock"
RESEND_API_KEY=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ClamAV (antivirus)
CLAMAV_HOST="localhost"
CLAMAV_PORT="3310"

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
