// Prisma Schema - Achat Location SaaS
// Production-ready schema with all required models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum UserRole {
  CLIENT
  OWNER
  ADMIN
  SUPER_ADMIN
}

enum PropertyStatus {
  AVAILABLE
  RESERVED
  RENTED
  SOLD
  OCCUPIED
  PENDING_VALIDATION
  SUSPENDED
  ARCHIVED
}

enum PropertyType {
  LAND
  HOUSE
  APARTMENT
  ROOM
  PASSING_ROOM
  HOTEL
  COMMERCIAL
}

enum TransactionType {
  RESERVATION
  RENT
  PURCHASE
  COMMISSION
  SUBSCRIPTION
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
  IN_ESCROW
}

enum SubscriptionPlan {
  MONTHLY
  QUARTERLY
  SEMESTRIAL
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  TRIAL
}

enum TrialType {
  GLOBAL
  MANUAL
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

// ============ MODELS ============

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  passwordHash          String    @map("password_hash")
  firstName             String    @map("first_name")
  lastName              String    @map("last_name")
  phone                 String?
  role                  UserRole  @default(CLIENT)
  emailVerified         Boolean   @default(false) @map("email_verified")
  kycVerified           Boolean   @default(false) @map("kyc_verified")
  avatarUrl             String?   @map("avatar_url")
  preferredLocale       String    @default("fr") @map("preferred_locale")
  
  // Trial
  trialStartDate        DateTime? @map("trial_start_date")
  trialEndDate          DateTime? @map("trial_end_date")
  isTrialActive         Boolean   @default(false) @map("is_trial_active")
  trialGrantedByAdmin   String?   @map("trial_granted_by_admin")
  trialType             TrialType? @map("trial_type")
  
  // Blocking
  isBlocked             Boolean   @default(false) @map("is_blocked")
  blockedReason         String?   @map("blocked_reason")
  blockedAt             DateTime? @map("blocked_at")
  blockedByAdminId      String?   @map("blocked_by_admin_id")
  
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  lastLoginAt           DateTime? @map("last_login_at")
  
  // Relations
  properties            Property[]
  favorites            Favorite[]
  clientRequests        ClientRequest[]
  transactionsAsClient  Transaction[] @relation("ClientTransactions")
  transactionsAsOwner   Transaction[] @relation("OwnerTransactions")
  subscriptions        Subscription[]
  refreshTokens         RefreshToken[]
  auditLogs             AuditLog[]
  commissions           Commission[]
  blockedBy             User?     @relation("BlockedUsers", fields: [blockedByAdminId], references: [id])
  blockedUsers         User[]    @relation("BlockedUsers")
}

model RefreshToken {
  id           String   @id @default(cuid())
  tokenHash    String   @unique @map("token_hash")
  userId       String   @map("user_id")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Country {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  nameFr    String?  @map("name_fr")
  nameEn    String?  @map("name_en")
  nameZh    String?  @map("name_zh")
  nameEs    String?  @map("name_es")
  nameAr    String?  @map("name_ar")
  isActive  Boolean  @default(true) @map("is_active")
  isSuspended Boolean @default(false) @map("is_suspended")
  
  cities    City[]
  properties Property[]
}

model City {
  id        String   @id @default(cuid())
  name      String
  nameFr    String?  @map("name_fr")
  slug      String
  countryId String   @map("country_id")
  
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  properties Property[]
}

model Property {
  id              String         @id @default(cuid())
  slug            String         @unique
  title           String
  description     String         @db.Text
  shortSummary    String?        @map("short_summary")
  
  type            PropertyType
  status          PropertyStatus @default(AVAILABLE)
  
  price           Decimal        @db.Decimal(12, 2)
  currency        String         @default("EUR")
  pricePerUnit    String?        @map("price_per_unit") // m², nuit, mois
  surfaceArea     Decimal?       @map("surface_area") @db.Decimal(10, 2)
  
  address         String
  neighborhood    String?        @map("neighborhood")
  postalCode      String?        @map("postal_code")
  latitude        Decimal?       @db.Decimal(10, 8)
  longitude       Decimal?       @db.Decimal(11, 8)
  
  countryId       String         @map("country_id")
  cityId          String         @map("city_id")
  
  isFurnished     Boolean        @default(false) @map("is_furnished")
  durationType    String?        @map("duration_type") // SHORT, LONG
  
  ownerId         String         @map("owner_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  publishedAt     DateTime?      @map("published_at")
  
  isListed        Boolean        @default(true) @map("is_listed")
  elasticId       String?        @map("elastic_id")
  
  owner           User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  country         Country        @relation(fields: [countryId], references: [id])
  city            City           @relation(fields: [cityId], references: [id])
  media           PropertyMedia[]
  statusHistory   PropertyStatusHistory[]
  clientRequests  ClientRequest[]
  transactions    Transaction[]
  favorites       Favorite[]
}

model PropertyStatusHistory {
  id          String         @id @default(cuid())
  propertyId  String         @map("property_id")
  oldStatus   PropertyStatus @map("old_status")
  newStatus   PropertyStatus @map("new_status")
  reason      String?        @db.Text
  userId      String         @map("user_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  
  property    Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model PropertyMedia {
  id         String    @id @default(cuid())
  propertyId String    @map("property_id")
  type       MediaType
  url        String
  thumbnail  String?
  metadata   Json?
  sortOrder  Int       @default(0) @map("sort_order")
  createdAt  DateTime  @default(now()) @map("created_at")
  
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model ClientRequest {
  id          String   @id @default(cuid())
  propertyId  String   @map("property_id")
  clientId    String   @map("client_id")
  message     String   @db.Text
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  client      User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Transaction {
  id              String            @id @default(cuid())
  type            TransactionType
  status          TransactionStatus @default(PENDING)
  amount          Decimal           @db.Decimal(12, 2)
  currency        String            @default("EUR")
  
  propertyId      String?           @map("property_id")
  clientId        String            @map("client_id")
  ownerId         String            @map("owner_id")
  
  stripePaymentId String?           @map("stripe_payment_id")
  mobileMoneyRef  String?           @map("mobile_money_ref")
  escrowId        String?           @map("escrow_id")
  
  metadata        Json?
  createdAt       DateTime         @default(now()) @map("created_at")
  completedAt     DateTime?        @map("completed_at")
  
  property        Property?        @relation(fields: [propertyId], references: [id])
  client          User             @relation("ClientTransactions", fields: [clientId], references: [id])
  owner           User             @relation("OwnerTransactions", fields: [ownerId], references: [id])
  commissions     Commission[]
}

model Escrow {
  id            String   @id @default(cuid())
  transactionId String   @unique @map("transaction_id")
  amount        Decimal  @db.Decimal(12, 2)
  currency      String   @default("EUR")
  status        String   @default("PENDING") // PENDING, RELEASED, REFUNDED
  releasedAt    DateTime? @map("released_at")
  createdAt     DateTime @default(now()) @map("created_at")
}

model Commission {
  id            String   @id @default(cuid())
  transactionId String   @map("transaction_id")
  userId        String   @map("user_id")
  amount        Decimal  @db.Decimal(12, 2)
  percentage    Decimal  @db.Decimal(5, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  user          User        @relation(fields: [userId], references: [id])
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String             @map("user_id")
  plan            SubscriptionPlan
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime           @map("start_date")
  endDate         DateTime           @map("end_date")
  stripeSubId     String?            @map("stripe_sub_id")
  stripePriceId   String?            @map("stripe_price_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  cancelledAt     DateTime?          @map("cancelled_at")
  
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  userId      String?  @map("user_id")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  
  user        User?    @relation(fields: [userId], references: [id])
}

model Settings {
  id                    String   @id @default(cuid())
  key                   String   @unique
  value                 Json
  
  // Trial
  defaultTrialDurationDays Int?   @map("default_trial_duration_days")
  isGlobalTrialEnabled     Boolean @default(false) @map("is_global_trial_enabled")
  
  // Commission
  commissionPercentage     Decimal? @map("commission_percentage") @db.Decimal(5, 2)
  
  // Theme
  globalTheme              String?  @map("global_theme")
  
  // Maintenance
  maintenanceMode          Boolean @default(false) @map("maintenance_mode")
  
  updatedAt             DateTime @updatedAt @map("updated_at")
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  propertyId String   @map("property_id")
  createdAt  DateTime @default(now()) @map("created_at")
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@unique([userId, propertyId])
}
